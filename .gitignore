# ============================================
# DEPENDENCIES
# node_modules is never committed — it's
# reinstalled via npm install from package.json
# ============================================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ============================================
# ENVIRONMENT VARIABLES
# NEVER commit .env files — they contain
# secrets like passwords and API keys
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# NEXT.JS BUILD OUTPUT
# These are generated automatically on build
# No need to commit them
# ============================================
.next/
out/
build/

# ============================================
# VERCEL DEPLOYMENT
# Generated by Vercel CLI — not needed in repo
# ============================================
.vercel

# ============================================
# TYPESCRIPT
# Build info cache — auto generated
# ============================================
*.tsbuildinfo
next-env.d.ts

# ============================================
# TESTING
# ============================================
/coverage

# ============================================
# OS FILES
# System files created automatically by
# Windows, Mac and Linux — not project files
# ============================================

# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================
# EDITOR FILES
# VSCode workspace settings that are personal
# and should not be shared with others
# ============================================
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# LOGS
# Log files generated during development
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# MISC
# ============================================
*.pem
.cache